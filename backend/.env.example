# ============================================================
# QMind Local Dev / Render / Fly.io environment variables
# Copy to .env and fill in your values
# ============================================================

# --- Database ---
# Neon free tier: https://neon.tech → Dashboard → Connection string
# Paste the full URL; the app auto-converts postgresql:// → postgresql+asyncpg://
DATABASE_URL=postgresql://user:password@ep-xxx.aws.neon.tech/qmind?sslmode=require

# --- Redis (OPTIONAL) ---
# Leave empty to use in-memory job tracking (fine for free tier)
# Upstash free: https://upstash.com → Create Database → Redis URL
REDIS_URL=

# --- Auth ---
# Set a strong random key; CLI sends this as Bearer token
API_KEY=your-secret-api-key-here

# --- AI Providers (bring your own keys) ---
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- Embedding config ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# --- LLM config ---
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

# --- Chunking ---
CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=150

# --- RAG ---
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7

# --- Upload ---
MAX_UPLOAD_SIZE_MB=100

# --- Honcho Memory Layer (OPTIONAL) ---
# Honcho gives your AI persistent memory about each user across sessions.
# Sign up at https://app.honcho.dev for $100 free credits, or self-host.
# Leave HONCHO_API_KEY empty to disable (app works fine without it).
HONCHO_API_KEY=
HONCHO_BASE_URL=                    # Leave empty for managed service
HONCHO_WORKSPACE_ID=qmind           # Logical grouping (any string)
